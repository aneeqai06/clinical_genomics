Bootstrap: docker
From: ubuntu:22.04

%post
    apt-get update && apt-get install -y \
        git \
        python3 \
        python3-pip \
        build-essential \
        zlib1g-dev \
        libbz2-dev \
        liblzma-dev \
        wget

    pip3 install --upgrade pip

    cd /opt

    # Correct Sniffles2 install
    git clone --recursive https://github.com/fritzsedlazeck/Sniffles.git

    cd Sniffles

    pip3 install .

%environment
    export PATH=/usr/local/bin:$PATH

%runscript
    exec sniffles "$@"

